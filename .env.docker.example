# Optional overrides for `docker compose`. Copy to `.env` to use.
# All of these already have inline defaults in docker-compose.yml, so the stack
# runs without this file — set values here only to override.

# Postgres credentials (applied to the postgres container and all services)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# RabbitMQ credentials
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

# Shared security secrets (JWT must match across gateway and user-health)
JWT_SECRET=pharmaflow-secret-key-2024-very-long-and-secure-key-for-production
INTERNAL_SERVICE_SECRET=pharmaflow-internal-secret-2024-very-secure

# Gateway CORS allow-list (frontend origin must be present)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4200
