{
  "info": {
    "name": "User Health Service API",
    "description": "Complete API collection for User Health Service with all endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Users",
      "item": [
        {
          "name": "Create User (Single)",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Marko\",\n  \"lastName\": \"Marković\",\n  \"email\": \"marko@pharmaflow.ba\",\n  \"password\": \"SecurePass123!\",\n  \"patientProfile\": {\n    \"weight\": 75.5,\n    \"height\": 180.0,\n    \"bloodType\": \"A+\",\n    \"allergies\": [\n      {\n        \"allergen\": \"Penicillin\",\n        \"severity\": \"High\",\n        \"activeSubstance\": \"Penicillin G\"\n      }\n    ],\n    \"therapies\": [\n      {\n        \"medicationName\": \"Aspirin\",\n        \"dosage\": \"100mg\",\n        \"frequency\": \"1x daily\"\n      }\n    ]\n  }\n}"
            },
            "url": {"raw": "http://localhost:8081/api/users", "host": ["localhost"], "port": "8081", "path": ["api", "users"]}
          }
        },
        {
          "name": "Batch Create Users",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "[\n  {\n    \"firstName\": \"Ana\",\n    \"lastName\": \"Anić\",\n    \"email\": \"ana@test.ba\",\n    \"password\": \"TestPass123!\"\n  },\n  {\n    \"firstName\": \"Petar\",\n    \"lastName\": \"Petrović\",\n    \"email\": \"petar@test.ba\",\n    \"password\": \"TestPass123!\"\n  },\n  {\n    \"firstName\": \"Jelena\",\n    \"lastName\": \"Jelenić\",\n    \"email\": \"jelena@test.ba\",\n    \"password\": \"TestPass123!\"\n  }\n]"
            },
            "url": {"raw": "http://localhost:8081/api/users/batch", "host": ["localhost"], "port": "8081", "path": ["api", "users", "batch"]}
          }
        },
        {
          "name": "Get All Users (Paginated)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:8081/api/users?page=0&size=10&sort=id,asc",
              "host": ["localhost"], "port": "8081", "path": ["api", "users"],
              "query": [
                {"key": "page", "value": "0"},
                {"key": "size", "value": "10"},
                {"key": "sort", "value": "id,asc"}
              ]
            }
          }
        },
        {
          "name": "Get User by ID",
          "request": {
            "method": "GET",
            "url": {"raw": "http://localhost:8081/api/users/1", "host": ["localhost"], "port": "8081", "path": ["api", "users", "1"]}
          }
        },
        {
          "name": "Filter Users by Email Domain",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:8081/api/users?emailDomain=pharmaflow.ba",
              "host": ["localhost"], "port": "8081", "path": ["api", "users"],
              "query": [{"key": "emailDomain", "value": "pharmaflow.ba"}]
            }
          }
        },
        {
          "name": "Update User (PUT)",
          "request": {
            "method": "PUT",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Updated\",\n  \"lastName\": \"User\",\n  \"email\": \"updated@test.ba\",\n  \"password\": \"NewPass123!\"\n}"
            },
            "url": {"raw": "http://localhost:8081/api/users/1", "host": ["localhost"], "port": "8081", "path": ["api", "users", "1"]}
          }
        },
        {
          "name": "Partial Update (PATCH)",
          "request": {
            "method": "PATCH",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "[\n  { \"op\": \"replace\", \"path\": \"/firstName\", \"value\": \"Patched Name\" },\n  { \"op\": \"replace\", \"path\": \"/email\", \"value\": \"patched@test.ba\" }\n]"
            },
            "url": {"raw": "http://localhost:8081/api/users/1", "host": ["localhost"], "port": "8081", "path": ["api", "users", "1"]}
          }
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "url": {"raw": "http://localhost:8081/api/users/1", "host": ["localhost"], "port": "8081", "path": ["api", "users", "1"]}
          }
        },
        {
          "name": "Validation Test (Should Fail)",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"M\",\n  \"lastName\": \"T\",\n  \"email\": \"invalid-email\",\n  \"password\": \"weak\"\n}"
            },
            "url": {"raw": "http://localhost:8081/api/users", "host": ["localhost"], "port": "8081", "path": ["api", "users"]}
          }
        }
      ]
    },
